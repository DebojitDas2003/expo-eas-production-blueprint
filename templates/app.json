{
  "expo": {
    "name": "YourAppName",
    "slug": "your-app-slug",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./src/assets/images/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "com.yourcompany.app",
    "ios": {
      "bundleIdentifier": "com.yourcompany.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "supportsTablet": false,
      "minimumOsVersion": "16.4",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to allow you to select and share photos.",
        "UIFileSharingEnabled": true,
        "LSSupportsOpeningDocumentsInPlace": true,
        "UIBackgroundModes": [
          "audio"
        ],
        "CFBundleURLTypes": [
          {
            "CFBundleTypeRole": "Editor",
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.YOUR-GOOGLE-CLIENT-ID-HERE"
            ]
          },
          {
            "CFBundleTypeRole": "Editor",
            "CFBundleURLName": "com.yourcompany.app",
            "CFBundleURLSchemes": [
              "com.yourcompany.app"
            ]
          }
        ]
      },
      "appleTeamId": "YOUR_APPLE_TEAM_ID_HERE"
    },
    "android": {
      "package": "com.yourcompany.app",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "VIBRATE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "com.yourcompany.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      "expo-apple-authentication",
      "expo-sqlite",
      [
        "expo-font",
        {
          "fonts": [
            "./src/assets/fonts/Lato-Regular.ttf",
            "./src/assets/fonts/Merriweather-Bold.ttf",
            "./src/assets/fonts/Merriweather-Regular.ttf",
            "./src/assets/fonts/VujahdayScript-Regular.ttf",
            "./src/assets/fonts/YoungSerif-Regular.ttf"
          ]
        }
      ],
      [
        "expo-video",
        {
          "supportsBackgroundPlayback": true,
          "supportsPictureInPicture": true
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.YOUR-GOOGLE-CLIENT-ID-HERE"
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-audio",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id-here"
      }
    },
    "owner": "your-expo-username",
    "runtimeVersion": "1.0.1",
    "updates": {
      "url": "https://u.expo.dev/your-eas-project-id-here"
    }
  }
}